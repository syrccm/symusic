rules_version = '2';

// ⚠️ 참고용 파일입니다. 자동 배포 연결(firebase.json/.firebaserc)이 없으므로
//    이 파일을 그대로 배포하면 안 됩니다. 콘솔에 수동 반영하세요.
//
// 반영 방법(기존 규칙 보존):
//   Firebase 콘솔 → Firestore Database → 규칙(Rules) 탭에서
//   현재 규칙은 그대로 두고, 아래 "── 설교노트" match 블록만
//   최상위 documents 블록 안에 추가합니다.

service cloud.firestore {
  match /databases/{database}/documents {

    // ===========================================================
    // 기존 규칙 보존 영역 (절대 삭제·수정 금지)
    // -----------------------------------------------------------
    // 콘솔에 현재 적용돼 있는 기존 match 블록들(예: notices, songs 등)을
    // 여기에 "그대로" 둡니다. 현재 규칙 전문을 모르는 상태이므로
    // 이 자리는 비워두지 말고, 콘솔의 기존 규칙을 그대로 유지하세요.
    //
    //   match /notices/{noticeId} { ... 기존 그대로 ... }
    //   match /songs/{songId}     { ... 기존 그대로 ... }
    //   ... (콘솔의 현재 규칙 전문) ...
    // ===========================================================


    // ── 설교노트 (신규 추가) ───────────────────────────────────
    // 로그인 없는 익명 기기ID 경로(sermonNotes/{deviceId})에 한해 읽기·쓰기 허용.
    // 기기ID는 추측이 어려운 무작위 문자열이며, 그 경로 밖에는 영향이 없습니다.
    match /sermonNotes/{deviceId} {
      allow read, write: if true;
      match /notes/{noteId} {
        allow read, write: if true;
      }
    }
  }
}
